# Compiled PocketBook binaries (built via Docker SDK / GitHub Actions, not committed)
*.app
*.exe

# Debug/run logs and adhoc test dumps produced while iterating locally
*.out
*.err
compilelog.txt
testrun*.txt
audit_result.txt
_exit.txt
_g_exit.txt
_g_stderr.txt
_g_stdout.txt
_stderr.txt
_stdout.txt
_test_out.txt

# Editor/tooling
.claude/
*.bak
*.bak2

# Play-test harness: generated screenshots and any stray Go workspace files
# (playtest/play.sh builds its go.work in a temp dir, but guard against copies)
playtest/_shots/
go.work
go.work.sum

# Runtime save/persistence files a game writes next to its own binary (cwd is
# chdir'd there in main); playtest runs from the module root so these can leak
# into the working tree during local `go test`/`playtest/play.sh` runs.
*.sav
*_best.txt

# OS
.DS_Store
Thumbs.db
